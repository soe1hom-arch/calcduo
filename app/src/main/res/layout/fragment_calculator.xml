<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/display_background"
    android:orientation="vertical">

    <!-- Display Area - compact Google style -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.60"
        android:background="@color/display_background"
        android:gravity="bottom|end"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp"
        android:paddingTop="8dp">

        <TextView
            android:id="@+id/tv_calculator_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:text="Calculator"
            android:textColor="@color/calculator_label"
            android:textSize="11sp"
            android:letterSpacing="0.05" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_expression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="start"
            android:gravity="end"
            android:lines="1"
            android:fontFamily="sans-serif"
            android:textColor="@color/btn_text_secondary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="start"
            android:gravity="end"
            android:maxLines="2"
            android:text="0"
            android:textColor="@color/btn_text_primary"
            android:textSize="44sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="-0.02"
            android:includeFontPadding="false" />

    </LinearLayout>

    <!-- Button Grid - Google Calculator layout (scientific mode) -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.40"
        android:columnCount="4"
        android:rowCount="7"
        android:paddingHorizontal="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp">

        <!-- Row 1: (   )   ⌫   AC -->
        <Button
            android:id="@+id/btn_parenthesis_open"
            style="@style/CalcButtonFunction"
            android:text="(" />
        <Button
            android:id="@+id/btn_parenthesis_close"
            style="@style/CalcButtonFunction"
            android:text=")" />
        <Button
            android:id="@+id/btn_backspace"
            style="@style/CalcButtonFunction"
            android:text="⌫" />
        <Button
            android:id="@+id/btn_clear"
            style="@style/CalcButtonClear"
            android:text="AC" />

        <!-- Row 2: π   e   √   x² -->
        <Button
            android:id="@+id/btn_pi"
            style="@style/CalcButtonFunction"
            android:text="π" />
        <Button
            android:id="@+id/btn_euler"
            style="@style/CalcButtonFunction"
            android:text="e" />
        <Button
            android:id="@+id/btn_sqrt"
            style="@style/CalcButtonFunction"
            android:text="√" />
        <Button
            android:id="@+id/btn_square"
            style="@style/CalcButtonFunction"
            android:text="x²" />

        <!-- Row 3: 1/x   xⁿ   %   ÷ -->
        <Button
            android:id="@+id/btn_reciprocal"
            style="@style/CalcButtonFunction"
            android:text="1/x" />
        <Button
            android:id="@+id/btn_power"
            style="@style/CalcButtonFunction"
            android:text="xⁿ" />
        <Button
            android:id="@+id/btn_percent"
            style="@style/CalcButtonFunction"
            android:text="%" />
        <Button
            android:id="@+id/btn_divide"
            style="@style/CalcButtonOperator"
            android:text="÷" />

        <!-- Row 4: 7   8   9   × -->
        <Button
            android:id="@+id/btn7"
            style="@style/CalcButtonNumber"
            android:text="7" />
        <Button
            android:id="@+id/btn8"
            style="@style/CalcButtonNumber"
            android:text="8" />
        <Button
            android:id="@+id/btn9"
            style="@style/CalcButtonNumber"
            android:text="9" />
        <Button
            android:id="@+id/btn_multiply"
            style="@style/CalcButtonOperator"
            android:text="×" />

        <!-- Row 5: 4   5   6   − -->
        <Button
            android:id="@+id/btn4"
            style="@style/CalcButtonNumber"
            android:text="4" />
        <Button
            android:id="@+id/btn5"
            style="@style/CalcButtonNumber"
            android:text="5" />
        <Button
            android:id="@+id/btn6"
            style="@style/CalcButtonNumber"
            android:text="6" />
        <Button
            android:id="@+id/btn_subtract"
            style="@style/CalcButtonOperator"
            android:text="−" />

        <!-- Row 6: 1   2   3   + -->
        <Button
            android:id="@+id/btn1"
            style="@style/CalcButtonNumber"
            android:text="1" />
        <Button
            android:id="@+id/btn2"
            style="@style/CalcButtonNumber"
            android:text="2" />
        <Button
            android:id="@+id/btn3"
            style="@style/CalcButtonNumber"
            android:text="3" />
        <Button
            android:id="@+id/btn_add"
            style="@style/CalcButtonOperator"
            android:text="+" />

        <!-- Row 7: ±   0   .   = -->
        <Button
            android:id="@+id/btn_toggle_sign"
            style="@style/CalcButtonFunction"
            android:text="±" />
        <Button
            android:id="@+id/btn0"
            style="@style/CalcButtonNumber"
            android:text="0" />
        <Button
            android:id="@+id/btn_decimal"
            style="@style/CalcButtonNumber"
            android:text="." />
        <Button
            android:id="@+id/btn_equals"
            style="@style/CalcButtonEquals"
            android:text="=" />

    </GridLayout>

</LinearLayout>
