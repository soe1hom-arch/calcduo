<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Main content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/md_theme_surface"
            android:elevation="4dp"
            app:title="CalcDuo"
            app:titleTextColor="@color/md_theme_onSurface" />

        <!-- Split container for dual calculators -->
        <LinearLayout
            android:id="@+id/ll_split_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="2" />

        <!-- Hidden fragment container for FragmentManager -->
        <FrameLayout
            android:id="@+id/fl_fragment_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Drawer content -->
    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/md_theme_surface"
        android:orientation="vertical">

        <!-- Drawer Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@color/md_theme_primaryContainer"
            android:gravity="bottom"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CalcDuo"
                android:textColor="@color/md_theme_onPrimaryContainer"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Multi-Calculator Workspace"
                android:textColor="@color/md_theme_onPrimaryContainer"
                android:textSize="14sp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:paddingBottom="8dp"
            android:text="Calculator Tabs"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_sidebar_tabs"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="8dp" />

        <TextView
            android:id="@+id/tv_empty_sidebar"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="32dp"
            android:text="No calculators yet. Tap + to add one."
            android:textColor="@color/btn_text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fab_add_calculator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="Add Calculator"
            android:textColor="@color/md_theme_onPrimaryContainer"
            android:contentDescription="Add new calculator tab"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="@color/md_theme_onPrimaryContainer"
            app:backgroundTint="@color/md_theme_primaryContainer" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
