<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/md_theme_surface"
            android:elevation="0dp"
            app:title="CalcDuo"
            app:titleTextColor="@color/md_theme_onSurface"
            app:titleCentered="false"
            app:logo="@mipmap/ic_launcher"
            app:logoScaleType="centerCrop"
            app:navigationIcon="@drawable/ic_menu"
            app:navigationContentDescription="@string/nav_open"
            style="@style/Widget.Material3.Toolbar"
            app:logoDescription="@string/app_name" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Left Panel -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_panel_left_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    android:text="Calculator A"
                    android:textColor="@color/calculator_label"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:visibility="gone" />

                <FrameLayout
                    android:id="@+id/panel_left"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

            </LinearLayout>

            <!-- Divider - subtle Material 3 -->
            <View
                android:id="@+id/panel_divider"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/divider_color"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- Right Panel -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_panel_right_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    android:text="Calculator B"
                    android:textColor="@color/calculator_label"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:visibility="gone" />

                <FrameLayout
                    android:id="@+id/panel_right"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_empty_state"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/empty_state"
            android:textColor="@color/btn_text_secondary"
            android:textSize="16sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Sidebar Drawer -->
    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/md_theme_surface"
        android:orientation="vertical"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@color/md_theme_primaryContainer"
            android:gravity="bottom"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CalcDuo"
                android:textColor="@color/md_theme_onPrimaryContainer"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Multi-Calculator Workspace"
                android:textColor="@color/md_theme_onPrimaryContainer"
                android:textSize="14sp"
                android:alpha="0.8" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp"
            android:text="Calculator Tabs"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_sidebar_tabs"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingHorizontal="12dp"
            android:paddingTop="4dp" />

        <TextView
            android:id="@+id/tv_empty_sidebar"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="32dp"
            android:text="No calculators yet. Tap + to add one."
            android:textColor="@color/btn_text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fab_add_calculator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="Add Calculator"
            android:textColor="@color/md_theme_onPrimaryContainer"
            android:contentDescription="Add new calculator tab"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="@color/md_theme_onPrimaryContainer"
            app:backgroundTint="@color/md_theme_primaryContainer" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
