<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Calculator Button -->
    <style name="CalcButtonBase">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

    <style name="CalcButtonNumber" parent="CalcButtonBase">
        <item name="android:background">@drawable/btn_number_bg</item>
        <item name="android:textColor">@color/btn_text_primary</item>
    </style>

    <style name="CalcButtonOperator" parent="CalcButtonBase">
        <item name="android:background">@drawable/btn_operator_bg</item>
        <item name="android:textColor">@color/btn_text_operator</item>
    </style>

    <style name="CalcButtonFunction" parent="CalcButtonBase">
        <item name="android:background">@drawable/btn_function_bg</item>
        <item name="android:textColor">@color/btn_text_primary</item>
    </style>

    <style name="CalcButtonClear" parent="CalcButtonBase">
        <item name="android:background">@drawable/btn_clear_bg</item>
        <item name="android:textColor">@color/btn_text_primary</item>
    </style>

    <style name="CalcButtonEquals" parent="CalcButtonBase">
        <item name="android:background">@drawable/btn_equals_bg</item>
        <item name="android:textColor">@color/btn_equals_text</item>
    </style>
</resources>
